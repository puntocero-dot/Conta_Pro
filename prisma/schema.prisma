generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  passwordHash   String
  role           Role            @default(CLIENTE)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  auditLogs      AuditLog[]
  companies      Company[]       @relation("CompanyToUser")
  companyGroups  CompanyGroup[]
  companyMembers CompanyMember[]
}

model Company {
  id             String          @id @default(uuid())
  name           String
  taxId          String          @unique
  country        String
  metadata       Json?
  groupId        String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  accounts       Account[]
  categories     Category[]
  journalEntries JournalEntry[]
  transactions   Transaction[]
  clients        AccountClient[]
  auditLogs      AuditLog[]
  users          User[]          @relation("CompanyToUser")
  group          CompanyGroup?   @relation(fields: [groupId], references: [id], onDelete: SetNull)
  members        CompanyMember[]
  payrolls       Payroll[]
  loans          Loan[]
  provisions     Provision[]
  fixedAssets    FixedAsset[]

  @@index([groupId])
}

model CompanyGroup {
  id        String    @id @default(uuid())
  name      String
  ownerId   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  owner     User      @relation(fields: [ownerId], references: [id])
  companies Company[]

  @@index([ownerId])
}

model CompanyMember {
  id        String   @id @default(uuid())
  userId    String
  companyId String
  role      Role     @default(CLIENTE)
  joinedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([companyId])
  @@index([userId])
}

model AccountClient {
  id        String   @id @default(uuid())
  name      String
  email     String?
  phone     String?
  nit       String?
  dui       String?
  address   String?
  type      String   @default("INDIVIDUAL") // INDIVIDUAL o EMPRESA
  companyId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company     Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  role        CounterpartyType @default(CLIENT)

  @@index([companyId])
}

model Category {
  id                String          @id @default(uuid())
  name              String
  type              TransactionType
  color             String          @default("#3b82f6")
  icon              String          @default("📁")
  companyId         String
  createdAt         DateTime        @default(now())
  debitAccountCode  String?         // cuenta que se debita (catálogo SV)
  creditAccountCode String?         // cuenta que se acredita (catálogo SV)
  company           Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  transactions      Transaction[]
}

model Transaction {
  id          String            @id @default(uuid())
  type        TransactionType
  status      TransactionStatus @default(ACTIVE)
  amount      Float
  description String
  date        DateTime
  categoryId  String
  companyId   String
  userId      String
  attachments Json?
  metadata    Json?
  dueDate     DateTime?         // fecha de vencimiento (CxC/CxP aging)
  isPaid      Boolean           @default(true)
  creditDays  Int?              // 30, 60, 90 días crédito
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  category    Category          @relation(fields: [categoryId], references: [id])
  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientId    String?
  client      AccountClient?    @relation(fields: [clientId], references: [id])

  @@index([companyId])
  @@index([userId])
  @@index([date])
  @@index([isPaid])
}

model AuditLog {
  id          String   @id @default(uuid())
  timestamp   DateTime @default(now())
  userId      String?
  companyId   String?
  action      String
  resource    String
  resourceId  String?
  ipAddress   String
  userAgent   String
  geoLocation Json?
  oldData     Json?
  newData     Json?
  result      String
  metadata    Json?
  user        User?    @relation(fields: [userId], references: [id])
  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([userId])
}

model Account {
  id        String             @id @default(uuid())
  code      String
  name      String
  type      String
  companyId String
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  company   Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines     JournalEntryLine[]

  @@unique([companyId, code])
}

model JournalEntry {
  id          String             @id @default(uuid())
  date        DateTime           @default(now())
  description String
  reference   String?
  companyId   String
  metadata    Json?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  company     Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines       JournalEntryLine[]

  @@index([companyId])
  @@index([date])
}

model JournalEntryLine {
  id             String       @id @default(uuid())
  journalEntryId String
  accountId      String
  debit          Float        @default(0)
  credit         Float        @default(0)
  account        Account      @relation(fields: [accountId], references: [id])
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  @@index([journalEntryId])
  @@index([accountId])
}

model CountryRule {
  id          String   @id @default(uuid())
  country     String
  triggerText String
  rules       Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([country, triggerText])
}

enum Role {
  SUPER_ADMIN
  CONTADOR
  CLIENTE
  AUDITOR
}

enum TransactionType {
  INGRESO
  EGRESO
}

enum CounterpartyType {
  CLIENT
  SUPPLIER
  BOTH
}

enum TransactionStatus {
  ACTIVE
  ANNULLED
  CORRECTED
}

// ─── PLANILLAS ──────────────────────────────────────────────────────────────

model Payroll {
  id                String           @id @default(uuid())
  companyId         String
  period            String           // "2025-01"
  status            PayrollStatus    @default(DRAFT)
  totalBruto        Float            @default(0)
  totalNeto         Float            @default(0)
  totalAFPLaboral   Float            @default(0)
  totalAFPPatronal  Float            @default(0)
  totalISSSLaboral  Float            @default(0)
  totalISSSPatronal Float            @default(0)
  totalINSAFORP     Float            @default(0)
  totalISR          Float            @default(0)
  totalCargaPatronal Float           @default(0)
  notes             String?
  transactionId     String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  company           Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees         PayrollEmployee[]

  @@index([companyId])
  @@index([period])
}

model PayrollEmployee {
  id              String   @id @default(uuid())
  payrollId       String
  clientId        String?
  employeeName    String
  jobTitle        String?
  employeeNumber  String?
  dui             String?
  nup             String?   // Número Único Previsional (AFP)
  afpName         String?   // AFP Crecer / AFP Confía
  salary          Float
  otrosIngresos   Float    @default(0)
  totalBruto      Float
  afpLaboral      Float    // 7.25% del salario
  isssLaboral     Float    // 3% del salario (max base $1,000)
  isrRetencion    Float    // Retención ISR tabla progresiva
  totalDescuentos Float
  salarioNeto     Float
  afpPatronal     Float    // 8.75% del salario
  isssPatronal    Float    // 7.5% del salario (max base $1,000)
  insaforp        Float    // 1% del salario (max base $1,000)
  createdAt       DateTime @default(now())
  payroll         Payroll  @relation(fields: [payrollId], references: [id], onDelete: Cascade)

  @@index([payrollId])
}

// ─── PRÉSTAMOS BANCARIOS ─────────────────────────────────────────────────────

model Loan {
  id              String        @id @default(uuid())
  companyId       String
  bankName        String
  description     String?
  originalAmount  Float
  balance         Float
  interestRate    Float         // tasa anual en porcentaje (ej: 8.5)
  termMonths      Int
  startDate       DateTime
  status          LoanStatus    @default(ACTIVE)
  metadata        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  payments        LoanPayment[]

  @@index([companyId])
}

model LoanPayment {
  id              String   @id @default(uuid())
  loanId          String
  paymentDate     DateTime
  totalPayment    Float
  principal       Float
  interest        Float
  balance         Float    // saldo después del pago
  transactionId   String?
  notes           String?
  createdAt       DateTime @default(now())
  loan            Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([loanId])
}

// ─── PREVISIONES ─────────────────────────────────────────────────────────────

model Provision {
  id              String        @id @default(uuid())
  companyId       String
  type            ProvisionType
  description     String
  year            Int
  month           Int
  accruedAmount   Float         @default(0)  // devengado (no mueve caja)
  paidAmount      Float         @default(0)  // pagado (mueve caja)
  transactionId   String?       // cuando se paga
  notes           String?
  metadata        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([year, month])
}

// ─── NUEVOS ENUMS ────────────────────────────────────────────────────────────

// ─── ACTIVOS FIJOS ────────────────────────────────────────────────────────────

model FixedAsset {
  id              String             @id @default(uuid())
  companyId       String
  name            String
  accountCode     String             // 1202, 1203, 1204, 1205, 1206, 1207
  purchaseDate    DateTime
  purchaseCost    Float
  residualValue   Float              @default(0)
  usefulLifeYears Int                // vida útil fiscal SV
  accumulatedDepr Float              @default(0)
  bookValue       Float              // purchaseCost - accumulatedDepr
  status          String             @default("ACTIVE") // ACTIVE, SOLD, SCRAPPED
  notes           String?
  metadata        Json?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  company         Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  depreciations   AssetDepreciation[]

  @@index([companyId])
}

model AssetDepreciation {
  id              String     @id @default(uuid())
  assetId         String
  year            Int
  month           Int
  amount          Float
  accumulatedDepr Float
  journalEntryId  String?
  createdAt       DateTime   @default(now())
  asset           FixedAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@unique([assetId, year, month])
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum PayrollStatus {
  DRAFT
  APPROVED
  PAID
  CANCELLED
}

enum LoanStatus {
  ACTIVE
  CLOSED
}

enum ProvisionType {
  VACATION       // Vacaciones (15 días + 30% recargo)
  AGUINALDO      // Aguinaldo (10-18 días según antigüedad)
  INDEMNIZACION  // Indemnización (15 días/año de servicio)
  BONO_SEMESTRAL // Bono semestral empresarial
  OTHER          // Otras previsiones
}
