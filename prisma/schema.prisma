generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             String          @id @default(uuid())
  email          String          @unique
  passwordHash   String
  role           Role            @default(CLIENTE)
  telegramId     String?         @unique
  metadata       Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  auditLogs      AuditLog[]
  companies      Company[]       @relation("CompanyToUser")
  companyGroups  CompanyGroup[]
  companyMembers CompanyMember[]
}

model Company {
  id                   String          @id @default(uuid())
  name                 String
  taxId                String          @unique
  country              String
  companyType          CompanyType?    // Tipo de sociedad mercantil
  localCurrency        String          @default("USD")
  presentationCurrency String          @default("USD")
  metadata             Json?
  groupId              String?
  createdAt            DateTime        @default(now())
  updatedAt            DateTime        @updatedAt
  accounts             Account[]
  categories           Category[]
  journalEntries       JournalEntry[]
  transactions         Transaction[]
  clients              AccountClient[]
  auditLogs            AuditLog[]
  users                User[]          @relation("CompanyToUser")
  group                CompanyGroup?   @relation(fields: [groupId], references: [id], onDelete: SetNull)
  members              CompanyMember[]
  payrolls             Payroll[]
  loans                Loan[]
  provisions           Provision[]
  fixedAssets          FixedAsset[]
  legalBooks           LegalBook[]
  complianceAlerts     ComplianceAlert[]

  @@index([groupId])
}

model CompanyGroup {
  id        String    @id @default(uuid())
  name      String
  ownerId   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  owner     User      @relation(fields: [ownerId], references: [id])
  companies Company[]

  @@index([ownerId])
}

model CompanyMember {
  id        String   @id @default(uuid())
  userId    String
  companyId String
  role      Role     @default(CLIENTE)
  joinedAt  DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([companyId])
  @@index([userId])
}

model AccountClient {
  id          String   @id @default(uuid())
  name        String
  email       String?
  phone       String?
  nit         String?
  dui         String?
  address     String?
  type        String   @default("INDIVIDUAL") // INDIVIDUAL o EMPRESA
  companyId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company      Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  role         CounterpartyType @default(CLIENT)
  kycRecords   KYCRecord[]

  @@index([companyId])
}

model Category {
  id                String          @id @default(uuid())
  name              String
  type              TransactionType
  color             String          @default("#3b82f6")
  icon              String          @default("📁")
  companyId         String
  createdAt         DateTime        @default(now())
  debitAccountCode  String?         // cuenta que se debita (catálogo SV)
  creditAccountCode String?         // cuenta que se acredita (catálogo SV)
  company           Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  transactions      Transaction[]
}

model Transaction {
  id          String            @id @default(uuid())
  type        TransactionType
  status      TransactionStatus @default(ACTIVE)
  amount      Float
  description String
  date        DateTime
  categoryId  String
  companyId   String
  userId      String
  attachments Json?
  metadata    Json?
  dueDate     DateTime?         // fecha de vencimiento (CxC/CxP aging)
  isPaid      Boolean           @default(true)
  creditDays  Int?              // 30, 60, 90 días crédito
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  category    Category          @relation(fields: [categoryId], references: [id])
  company     Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  clientId    String?
  client      AccountClient?    @relation(fields: [clientId], references: [id])

  @@index([companyId])
  @@index([userId])
  @@index([date])
  @@index([isPaid])
}

model AuditLog {
  id          String   @id @default(uuid())
  timestamp   DateTime @default(now())
  userId      String?
  companyId   String?
  action      String
  resource    String
  resourceId  String?
  ipAddress   String
  userAgent   String
  geoLocation Json?
  oldData     Json?
  newData     Json?
  result      String
  metadata    Json?
  user        User?    @relation(fields: [userId], references: [id])
  company     Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([userId])
}

model Account {
  id        String             @id @default(uuid())
  code      String
  name      String
  type      String
  companyId String
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  company   Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines     JournalEntryLine[]

  @@unique([companyId, code])
}

model JournalEntry {
  id          String             @id @default(uuid())
  date        DateTime           @default(now())
  description String
  reference   String?
  companyId   String
  metadata    Json?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  company     Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  lines       JournalEntryLine[]

  @@index([companyId])
  @@index([date])
}

model JournalEntryLine {
  id             String       @id @default(uuid())
  journalEntryId String
  accountId      String
  debit          Float        @default(0)
  credit         Float        @default(0)
  account        Account      @relation(fields: [accountId], references: [id])
  journalEntry   JournalEntry @relation(fields: [journalEntryId], references: [id], onDelete: Cascade)

  @@index([journalEntryId])
  @@index([accountId])
}

model CountryRule {
  id          String   @id @default(uuid())
  country     String
  triggerText String
  rules       Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([country, triggerText])
}

enum Role {
  SUPER_ADMIN
  CONTADOR
  CLIENTE
  AUDITOR
}

enum TransactionType {
  INGRESO
  EGRESO
}

enum CounterpartyType {
  CLIENT
  SUPPLIER
  BOTH
}

enum TransactionStatus {
  ACTIVE
  ANNULLED
  CORRECTED
  PENDING_APPROVAL
}

enum CompanyType {
  SA              // Sociedad Anónima
  SAS             // Sociedad por Acciones Simplificadas
  SRL             // Sociedad de Responsabilidad Limitada
  SNC             // Sociedad en Nombre Colectivo
  COOPERATIVA
  PERSONA_NATURAL
}

// ─── PLANILLAS ──────────────────────────────────────────────────────────────

model Payroll {
  id                String           @id @default(uuid())
  companyId         String
  period            String           // "2025-01"
  status            PayrollStatus    @default(DRAFT)
  totalBruto        Float            @default(0)
  totalNeto         Float            @default(0)
  totalAFPLaboral   Float            @default(0)
  totalAFPPatronal  Float            @default(0)
  totalISSSLaboral  Float            @default(0)
  totalISSSPatronal Float            @default(0)
  totalINSAFORP     Float            @default(0)
  totalISR          Float            @default(0)
  totalCargaPatronal Float           @default(0)
  notes             String?
  transactionId     String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  company           Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  employees         PayrollEmployee[]

  @@index([companyId])
  @@index([period])
}

model PayrollEmployee {
  id              String   @id @default(uuid())
  payrollId       String
  clientId        String?
  employeeName    String
  jobTitle        String?
  employeeNumber  String?
  dui             String?
  nup             String?   // Número Único Previsional (AFP)
  afpName         String?   // AFP Crecer / AFP Confía
  salary          Float
  otrosIngresos   Float    @default(0)
  totalBruto      Float
  afpLaboral      Float    // 7.25% del salario
  isssLaboral     Float    // 3% del salario (max base $1,000)
  isrRetencion    Float    // Retención ISR tabla progresiva
  totalDescuentos Float
  salarioNeto     Float
  afpPatronal     Float    // 8.75% del salario
  isssPatronal    Float    // 7.5% del salario (max base $1,000)
  insaforp        Float    // 1% del salario (max base $1,000)
  // ── Licencias remuneradas ─────────────────────────────────
  licenciaDias    Int?     // Días de licencia remunerada en el período
  licenciaTipo    String?  // PATERNIDAD, OBLIGACION_PUBLICA, LUTO, etc.
  createdAt       DateTime @default(now())
  payroll         Payroll  @relation(fields: [payrollId], references: [id], onDelete: Cascade)

  @@index([payrollId])
}

// ─── PRÉSTAMOS BANCARIOS ─────────────────────────────────────────────────────

model Loan {
  id              String        @id @default(uuid())
  companyId       String
  bankName        String
  description     String?
  originalAmount  Float
  balance         Float
  interestRate    Float         // tasa anual en porcentaje (ej: 8.5)
  termMonths      Int
  startDate       DateTime
  status          LoanStatus    @default(ACTIVE)
  metadata        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  payments        LoanPayment[]

  @@index([companyId])
}

model LoanPayment {
  id              String   @id @default(uuid())
  loanId          String
  paymentDate     DateTime
  totalPayment    Float
  principal       Float
  interest        Float
  balance         Float    // saldo después del pago
  transactionId   String?
  notes           String?
  createdAt       DateTime @default(now())
  loan            Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([loanId])
}

// ─── PREVISIONES ─────────────────────────────────────────────────────────────

model Provision {
  id              String        @id @default(uuid())
  companyId       String
  type            ProvisionType
  description     String
  year            Int
  month           Int
  accruedAmount   Float         @default(0)  // devengado (no mueve caja)
  paidAmount      Float         @default(0)  // pagado (mueve caja)
  transactionId   String?       // cuando se paga
  notes           String?
  metadata        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  company         Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([year, month])
}

// ─── NUEVOS ENUMS ────────────────────────────────────────────────────────────

// ─── ACTIVOS FIJOS ────────────────────────────────────────────────────────────

model FixedAsset {
  id                   String             @id @default(uuid())
  companyId            String
  name                 String
  accountCode          String             // 1202, 1203, 1204, 1205, 1206, 1207
  purchaseDate         DateTime
  purchaseCost         Float
  residualValue        Float              @default(0)
  usefulLifeYears      Int                // vida útil fiscal SV (tabla Ley ISR)
  accumulatedDepr      Float              @default(0)
  bookValue            Float              // purchaseCost - accumulatedDepr (fiscal)
  // ── Campos NIIF (Sección 17) ──────────────────────────────────
  niifUsefulLifeYears  Int?               // vida útil estimada real (juicio profesional)
  niifResidualValue    Float?             // valor residual NIIF
  niifAccumulatedDepr  Float              @default(0)
  niifBookValue        Float?             // valor en libros NIIF
  // ──────────────────────────────────────────────────────────────
  status               String             @default("ACTIVE") // ACTIVE, SOLD, SCRAPPED
  notes                String?
  metadata             Json?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  company              Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  depreciations        AssetDepreciation[]

  @@index([companyId])
}

model AssetDepreciation {
  id               String     @id @default(uuid())
  assetId          String
  year             Int
  month            Int
  amount           Float
  accumulatedDepr  Float
  depreciationType String     @default("FISCAL") // FISCAL | NIIF
  journalEntryId   String?
  createdAt        DateTime   @default(now())
  asset            FixedAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@unique([assetId, year, month, depreciationType])
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum PayrollStatus {
  DRAFT
  APPROVED
  PAID
  CANCELLED
}

enum LoanStatus {
  ACTIVE
  CLOSED
}

enum ProvisionType {
  VACATION       // Vacaciones (15 días + 30% recargo)
  AGUINALDO      // Aguinaldo (10-18 días según antigüedad)
  INDEMNIZACION  // Indemnización (15 días/año de servicio)
  BONO_SEMESTRAL // Bono semestral empresarial
  OTHER          // Otras previsiones
}

// ─── LIBROS LEGALES ──────────────────────────────────────────────────────────

model LegalBook {
  id          String   @id @default(uuid())
  companyId   String
  type        String   // ACTAS, ACCIONISTAS, CAPITAL_VARIABLE, DIARIO, MAYOR
  title       String
  content     Json     // Contenido del acta o registro
  folioNumber Int?     // Número de folio (hojas legalizadas)
  date        DateTime
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([type])
}

// ─── CUMPLIMIENTO ANTI-LAVADO (UIF) ──────────────────────────────────────────

model ComplianceAlert {
  id              String    @id @default(uuid())
  companyId       String
  transactionId   String?
  alertType       String    // THRESHOLD_EXCEEDED, STRUCTURING_SUSPECTED, MANUAL
  amount          Float
  description     String
  status          String    @default("PENDING") // PENDING, REVIEWED, REPORTED, DISMISSED
  reviewedBy      String?   // userId del Oficial de Cumplimiento
  reviewedAt      DateTime?
  reportNumber    String?   // Número de ROS si fue reportado a UIF
  metadata        Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  company         Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([status])
  @@index([alertType])
}

model KYCRecord {
  id                 String        @id @default(uuid())
  clientId           String
  companyId          String
  riskLevel          String        @default("LOW") // LOW, MEDIUM, HIGH, PEP
  sourceOfFunds      String?
  occupation         String?
  annualIncome       Float?
  politicallyExposed Boolean       @default(false)
  kycFormData        Json?         // Formulario de Identificación del Cliente (UIF)
  documents          Json?         // Lista de documentos adjuntos
  verifiedAt         DateTime?
  verifiedBy         String?
  expiresAt          DateTime?
  status             String        @default("PENDING") // PENDING, VERIFIED, EXPIRED, REJECTED
  notes              String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  client             AccountClient @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([companyId])
  @@index([riskLevel])
  @@unique([clientId, companyId])
}

// ─── REGLAS FISCALES CONFIGURABLES ───────────────────────────────────────────

model TaxRule {
  id            String    @id @default(uuid())
  countryCode   String    // "SV", "GT", "HN"
  ruleType      String    // "IVA", "ISR", "PAGO_A_CUENTA", "AFP_LABORAL", etc.
  name          String
  rate          Float     // Tasa en decimal (0.13 para 13%)
  threshold     Float?    // Umbral si aplica (ej. $150k para ISR 30%)
  maxBase       Float?    // Base máxima (ej. $1000 ISSS)
  effectiveFrom DateTime
  effectiveTo   DateTime?
  metadata      Json?
  createdAt     DateTime  @default(now())

  @@index([countryCode, ruleType])
  @@unique([countryCode, ruleType, effectiveFrom])
}
model BotSession {
  id         String   @id @default(uuid())
  telegramId String   @unique
  step       String   // Estado en la máquina (ej: SELECT_COMPANY, ENTER_AMOUNT...)
  data       Json?    // Contexto temporal (companyId, categoryId, amount)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Lead {
  id        String   @id @default(uuid())
  email     String
  name      String?
  phone     String?
  plan      String   // STARTER, PROFESSIONAL, ENTERPRISE
  status    String   @default("NEW") // NEW, CONTACTED, CONVERTED, LOST
  userId    String?  // Si el lead se creó desde un usuario registrado
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status])
}
